---
// src/pages/404.astro — shown by the host for any unknown URL
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="not found — stephanie liu">
  <div class="col">
    <p class="oops">this page doesn't exist</p>
    <p class="hint"><a href="/">&larr; back to stephanie liu</a></p>
  </div>
</BaseLayout>

<style>
  .oops {
    margin-top: var(--space-9);
    font-size: var(--text-xl);
    line-height: 1.9;
    letter-spacing: -0.01em;
  }
  .hint { font-size: var(--text-base); margin-top: var(--space-2); }

  @media (max-width: 640px) {
    .oops { margin-top: var(--space-6); font-size: var(--text-lg); }
  }
</style>
