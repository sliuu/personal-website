---
// src/pages/projects/[id].astro — renders every project from the collection
// https://pixelarticons.com/
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Tell Astro which pages to build — one per markdown file in content/projects/
export async function getStaticPaths() {
  // Skip drafts/archived — no page is built for them.
  const projects = (await getCollection('projects')).filter((p) => !p.data.draft);
  return projects.map((project) => ({
    params: { id: project.id },   // the URL slug, from the filename
    props: { project },           // hand the whole entry to the page below
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);   // markdown body → renderable component

// Ordered list (newest first) so we can offer a "next case study" link.
// Exclude drafts so archived projects never surface as "Next".
const all = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.year - a.data.year || a.data.title.localeCompare(b.data.title));
const index = all.findIndex((p) => p.id === project.id);
const next = all[(index + 1) % all.length];   // wraps around to the first

const linkedinUrl = "https://www.linkedin.com/in/stephanieliu14";
---
<BaseLayout title={`${project.data.title} — stephanie liu`} description={project.data.summary}>
  <article class="col">
    <a class="back" href="/" aria-label="back to home">&larr;</a>
    <h1>{project.data.title}</h1>

    <div class="summary">{project.data.summary}</div>
    <dl class="meta-block">
      <div><dt>Team</dt><dd>{project.data.team}</dd></div>
      <div><dt>Role</dt><dd>{project.data.role}</dd></div>
      <div><dt>Date</dt><dd>{project.data.date}</dd></div>
      <div><dt>Tools</dt><dd>{project.data.tech.join(", ")}</dd></div>
      {project.data.repo && (
        <div><dt>Code</dt><dd><a href={project.data.repo} target="_blank" rel="noopener">GitHub &#8599;</a></dd></div>
      )}
    </dl>

    <Content />

    <footer class="case-footer">
      <a class="case-footer__home" href="/">&larr; All work</a>
      <a class="case-footer__next" href={`/projects/${next.id}`}>
        Next: {next.data.title} &rarr;
      </a>
    </footer>
    <p class="case-cta">Want to talk? <a href={linkedinUrl} target="_blank" rel="noopener">Get in touch &#8599;</a></p>
  </article>

  <style>
    .back {
      display: inline-block;
      margin-top: var(--space-8);
      font-size: var(--text-xl);
      line-height: 1;
      transition: transform 0.2s ease, filter 0.2s ease;
    }
    .back:hover { transform: translateX(-4px); }
    article h1 {
      margin-top: var(--space-2);
      font-size: var(--text-xl);
      color: var(--cream);
      margin-bottom: var(--space-4);
      font-weight: 400;
    }
    .summary {
      color: var(--muted);
      margin-bottom: var(--space-4);
      font-size: var(--text-base);
      line-height: 1.5;
    }
    /* labeled metadata row under the title — 4-column grid.
       minmax(0, 1fr) lets columns shrink so long values wrap instead of
       overflowing; without it, tracks default to min-content and push wide. */
    .meta-block {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: var(--space-4) var(--space-3);
      margin: 0 0 var(--space-6);
      padding-bottom: var(--space-4);
      border-bottom: 1.5px dashed var(--line-soft);
    }
    .meta-block dt {
      font-size: var(--text-sm);
      color: var(--muted);
      margin-bottom: 2px;
    }
    .meta-block dd {
      margin: 0;
      font-size: var(--text-base);
      color: var(--cream);
      overflow-wrap: break-word;
    }

    /* --- project page content (markdown) --- */
    article :global(h1) {
      font-size: var(--text-xl);
      line-height: 1.3;
      letter-spacing: -0.01em;
      color: var(--cream);
      margin-bottom: 0.25rem;
    }
    article :global(h2) {
      font-size: var(--text-lg);
      color: var(--muted);
      margin: var(--space-8) 0 var(--space-2);
      font-weight: 500;
    }
    article :global(h3) {
      font-size: var(--text-base);
      color: var(--muted);
      margin: var(--space-3) 0 var(--space-1);
    }
    article :global(h4) {
      font-size: var(--text-base);
      color: var(--muted);
      margin: var(--space-3) 0 0;
      font-weight: 500;
    }
    article :global(p),
    article :global(li) {
      font-size: var(--text-base);
      line-height: 1.6;
      color: var(--cream);
    }
    /* the company/duration blurb under the title */
    article :global(.meta) {
      font-size: var(--text-base);
      color: var(--muted);
      margin-bottom: var(--space-4);
    }
    article :global(.callout) {
      border: 1px solid var(--cream);
      padding: 0 var(--space-2) var(--space-1);
      margin: 0 0 var(--space-3) 0;
    }
    article :global(.callout p) {
      font-size: var(--text-sm);
    }

    article :global(img) {
      max-width: 100%;
      width: 100%;
      height: auto;
      display: block;
      margin: var(--space-2) 0;
      /* border: 1px solid rgba(238, 224, 224, 0.08); */
      /* border-radius: 2px; */
    }
    article :global(figure) {
      margin: var(--space-4) 0;
    }
    article :global(figcaption) {
      font-size: var(--text-sm);
      color: var(--muted);
      /* margin-top: var(--space-1); */
    }
    article :global(.cols-3) {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-4);
    }
    /* inline pixel icons (fill="currentColor") — muted so they stay
       decorative (gold is reserved for clickable things).
       auto side margins center the block icon in its callout. */
    article :global(.minisvg) {
      width: 30px;
      height: 30px;
      display: block;
      margin: var(--space-3) auto var(--space-2);
      color: var(--gold);
    }

    /* the challenge heading: icon + label on one line */
    article :global(.challenge-head) {
      display: flex;
      align-items: center;
      gap: 0.4em;
    }
    /* inline variant — small, sits with the text, no centering.
       compound selector so it beats the base .minisvg regardless of order. */
    article :global(.minisvg.minisvg--inline) {
      width: 1.1em;
      height: 1.1em;
      display: inline-block;
      margin: 0;
      flex: none;
    }

    /* end-of-page navigation */
    .case-footer {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: var(--space-3);
      margin-top: var(--space-7);
      padding-top: var(--space-3);
      border-top: 1.5px dashed var(--line-soft);
      font-size: var(--text-base);
    }
    .case-footer__next { text-align: right; }
    .case-cta { font-size: var(--text-base); color: var(--muted); margin-top: var(--space-3); }

    @media (max-width: 640px) {
      .back { margin-top: var(--space-6); }
      .meta-block { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .case-footer { flex-direction: column; gap: var(--space-2); }
      .case-footer__next { text-align: left; }
    }
  </style>
</BaseLayout>